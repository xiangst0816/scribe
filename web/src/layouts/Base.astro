---
import { defaultLang, languages } from '../i18n/ui';
import { useTranslations, htmlLangAttr } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const { lang = defaultLang, title, description } = Astro.props;
const t = useTranslations(lang);
const pageTitle = title ?? t('meta.title');
const pageDesc = description ?? t('meta.description');
const htmlLang = htmlLangAttr[lang];

const altLinks = (Object.keys(languages) as Lang[]).map((l) => {
  const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
  const path = l === defaultLang ? `${base}/` : `${base}/${l}/`;
  return { lang: htmlLangAttr[l], href: path };
});
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    {altLinks.map((l) => (
      <link rel="alternate" hreflang={l.lang} href={new URL(l.href, Astro.site).toString()} />
    ))}
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(`${import.meta.env.BASE_URL}/og-image.png`, Astro.site).toString()} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('scribe-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (_) {
          /* no-op */
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Light theme tokens */
    --bg: #ffffff;
    --bg-page:
      radial-gradient(circle at 18% 6%, rgba(89, 139, 255, 0.14), transparent 28rem),
      radial-gradient(circle at 88% 0%, rgba(59, 201, 179, 0.12), transparent 24rem),
      #f7f5f0;

    --surface: rgba(255, 255, 255, 0.7);
    --surface-strong: #ffffff;
    --surface-mute: rgba(255, 255, 255, 0.58);
    --surface-glass: rgba(255, 255, 255, 0.72);
    --surface-glass-strong: rgba(255, 255, 255, 0.78);

    --ink: #111827;
    --ink-strong: #020617;
    --ink-soft: rgba(17, 24, 39, 0.78);
    --ink-mute: rgba(17, 24, 39, 0.66);
    --ink-faint: rgba(17, 24, 39, 0.55);
    --ink-fade: rgba(17, 24, 39, 0.16);
    --ink-inv: #ffffff;

    --border: rgba(17, 24, 39, 0.08);
    --border-strong: rgba(17, 24, 39, 0.1);

    --blue: #155eef;
    --blue-soft: #eef4ff;
    --shadow-card: 0 18px 50px rgba(27, 35, 48, 0.08);
    --shadow-button: 0 14px 30px rgba(17, 24, 39, 0.18);
    --shadow-button-hover: 0 18px 40px rgba(17, 24, 39, 0.22);

    /* Dark-section tokens (privacy / detail-card.dark) — kept dark in light mode */
    --darksec-bg: #121826;
    --darksec-fg: #ffffff;
    --darksec-fg-mute: rgba(255, 255, 255, 0.68);

    --r-card: 12px;
    --r-card-lg: 16px;
    --r-pill: 9999px;
    --max: 1200px;
    --gutter: 24px;

    font-family:
      'Inter', -apple-system, BlinkMacSystemFont, system-ui, 'Segoe UI',
      'PingFang SC', 'Noto Sans SC', 'Hiragino Sans GB', 'Microsoft YaHei',
      Helvetica, Arial, sans-serif;
    font-feature-settings: 'lnum' 1, 'locl' 1;

    color-scheme: light;
  }

  :root[data-theme='dark'] {
    --bg: #0b0d12;
    --bg-page:
      radial-gradient(circle at 18% 6%, rgba(89, 139, 255, 0.18), transparent 28rem),
      radial-gradient(circle at 88% 0%, rgba(59, 201, 179, 0.12), transparent 24rem),
      #0b0d12;

    --surface: rgba(255, 255, 255, 0.04);
    --surface-strong: #14171f;
    --surface-mute: rgba(255, 255, 255, 0.03);
    --surface-glass: rgba(20, 23, 31, 0.72);
    --surface-glass-strong: rgba(20, 23, 31, 0.82);

    --ink: #f3f4f6;
    --ink-strong: #ffffff;
    --ink-soft: rgba(243, 244, 246, 0.82);
    --ink-mute: rgba(243, 244, 246, 0.66);
    --ink-faint: rgba(243, 244, 246, 0.5);
    --ink-fade: rgba(243, 244, 246, 0.18);
    --ink-inv: #0b0d12;

    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.12);

    --blue: #6aa6ff;
    --blue-soft: rgba(106, 166, 255, 0.14);
    --shadow-card: 0 18px 50px rgba(0, 0, 0, 0.4);
    --shadow-button: 0 14px 30px rgba(0, 0, 0, 0.5);
    --shadow-button-hover: 0 18px 40px rgba(0, 0, 0, 0.55);

    --darksec-bg: #06080d;
    --darksec-fg: #ffffff;
    --darksec-fg-mute: rgba(255, 255, 255, 0.66);

    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    background: var(--bg);
    color: var(--ink);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  ::selection {
    background: var(--blue);
    color: #fff;
  }

  :focus-visible {
    outline: 2px solid var(--blue);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
